# Copy this file to .env for local dev, or .env.production for production builds.

# https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_API_KEY=

# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_API_KEY=

# https://{org}.maps.arcgis.com/home/content.html
VITE_ARCGIS_API_KEY=

# Offline tile server URL (optional, for Node backend)
VITE_TILE_SERVER_URL=http://localhost:3456
